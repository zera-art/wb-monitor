# Скопируйте этот файл в .env и заполните своими ключами
# cp .env.example .env

# === Wildberries API Keys ===
WB_KEY_STATS=ваш_ключ_статистики
WB_KEY_CONTENT=ваш_ключ_контента
WB_KEY_PRICES=ваш_ключ_цен
WB_KEY_ANALYTICS=ваш_ключ_аналитики
WB_KEY_ADS=ваш_ключ_рекламы

# === Google Sheets ===
SPREADSHEET_ID=id_вашей_таблицы
GOOGLE_CREDENTIALS_PATH=google_credentials.json

# === Telegram (опционально) ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
